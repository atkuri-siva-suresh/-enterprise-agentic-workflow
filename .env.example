# ============================================================
# Enterprise Agentic Workflow — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# cp .env.example .env

# ── LLM Provider ─────────────────────────────────────────────
# Options: groq (default, free), anthropic, ollama (local)
LLM_PROVIDER=groq

# ── Groq (FREE — recommended) ────────────────────────────────
# Sign up free at https://console.groq.com (no credit card)
# Takes 2 minutes, generous free tier
GROQ_API_KEY=gsk_your_groq_key_here

# ── Anthropic (optional) ──────────────────────────────────────
# Only needed if LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Ollama (optional, fully local) ───────────────────────────
# Only needed if LLM_PROVIDER=ollama
# Run: ollama pull llama3.2   then set LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434

# ── Model Overrides (optional) ───────────────────────────────
# Leave blank to use provider defaults (recommended)
# MODEL_NAME=llama-3.3-70b-versatile
# FAST_MODEL_NAME=llama-3.1-8b-instant

# ── LangSmith Observability (optional) ───────────────────────
# Free tier at https://smith.langchain.com
LANGCHAIN_TRACING_V2=false
# LANGCHAIN_API_KEY=ls__your-key-here
# LANGCHAIN_PROJECT=enterprise-agentic-workflow

# ── App Settings ─────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
MAX_ITERATIONS=10
API_HOST=0.0.0.0
API_PORT=8000
